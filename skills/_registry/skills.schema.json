{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skills.schema.json",
  "title": "DDD Skills Catalog Schema",
  "type": "object",
  "required": [
    "version",
    "skills"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "owner_agent",
        "stage",
        "artifacts_produced",
        "inputs",
        "outputs",
        "memory_writes",
        "quality_gates"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner_agent": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "enum": [
            "A1-discovery",
            "A2-event-storming",
            "A3-subdomains",
            "A4-bounded-contexts",
            "A5-domain-model",
            "A6-specification"
          ]
        },
        "artifacts_produced": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "memory_writes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/memoryWrite"
          }
        },
        "quality_gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompts": {
          "description": "Required when the skill defines prompt templates.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "scripts": {
          "description": "Required when the skill depends on executable scripts.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "references": {
          "description": "Required when the skill uses external or bundled references.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "assets": {
          "description": "Required when the skill needs static assets.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "memoryWrite": {
      "type": "object",
      "required": [
        "target",
        "reason"
      ],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
