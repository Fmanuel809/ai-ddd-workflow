          "target": "engram:ddd.session",
          "reason": "When backend=engram, persist intake stage checkpoint"
        }
      ],
      "quality_gates": [
        "Problem statement is explicit and testable",
        "In-scope and out-of-scope boundaries are documented",
        "Constraints and assumptions are explicit",
        "Material unknowns are captured as open questions"
      ],
